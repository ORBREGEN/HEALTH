# HEALTH — Environment Configuration
# Copy this file to .env and fill in the values.

# ── Application ────────────────────────────────────────────────────────────────
# DEBUG=true

# ── Supabase ───────────────────────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_your_key_here

# The address all platform emails are sent from.
# Must be a verified domain in your Resend account.
FROM_EMAIL=Senebiclabs <noreply@senebiclabs.com>

# Where admin alerts (new applications) are delivered.
ADMIN_EMAIL=you@yourdomain.com

# ── Admin ──────────────────────────────────────────────────────────────────────
# Secret key required to approve/reject expert applications via the API.
# Generate one: openssl rand -hex 32
# Usage: POST /api/v1/expert/{id}/review  with header  X-Admin-Key: <this value>
ADMIN_API_KEY=your-strong-random-key

# ── Reasoning engine ───────────────────────────────────────────────────────────
# Required for POST /api/v1/interpret
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key
