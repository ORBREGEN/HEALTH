# HEALTH — Environment Configuration
# Copy this file to .env and edit as needed.
# All settings have sensible defaults; only override what you need.

# ── Application ───────────────────────────────────────────────────────────────

# Enable debug mode (verbose logging, auto-reload hint in startup banner)
# DEBUG=true

# ── File system ───────────────────────────────────────────────────────────────

# Absolute path to the directory where .h5ad dataset files are stored.
# Default: <project_root>/data/
# DATA_DIR=/mnt/large-disk/hlca_data

# Absolute path to the directory where ML model files are stored.
# Default: <project_root>/models/
# MODELS_DIR=/mnt/large-disk/hlca_models

# ── Reasoning Engine ──────────────────────────────────────────────────────────

# Anthropic API key — required for POST /api/v1/interpret
# Get one at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...
